# COPY THIS FILE TO .env AND FILL IN YOUR VALUES
# NUNCA COMMIT .env - APENAS .env.example
#
# Para obter essas valores:
# 1. Ir para Supabase Dashboard (https://app.supabase.com)
# 2. Projeto > Settings > API
# 3. Copiar os valores abaixo com segurança (NUNCA compartilhar SERVICE_ROLE)

# ✅ SAFE - Pode ficar em repositório público
VITE_SUPABASE_PROJECT_ID="seu_project_id_aqui"
VITE_SUPABASE_PUBLISHABLE_KEY="sua_publishable_key_aqui"
VITE_SUPABASE_URL="https://seu_project.supabase.co"

# ❌ SECRET - NUNCA versioná-la! Use Vercel/GitHub Secrets em produção
# VITE_SUPABASE_SERVICE_ROLE_KEY="sua_service_role_key_VIA_ENVIRONMENT_ONLY"
